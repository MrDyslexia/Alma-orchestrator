PORT=3000
NODE_ENV=development

STT_BASE_URL=http://localhost:8001
STT_TIMEOUT_MS=10000

LLM_BASE_URL=http://localhost:11434
LLM_MODEL=qwen3:14b
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.7

TTS_BASE_URL=http://localhost:8002
TTS_TIMEOUT_MS=15000
TTS_EXAGGERATION=0.4
TTS_CFG_WEIGHT=0.4

AUDIO_SAMPLE_RATE=16000
AUDIO_CHUNK_SIZE=4096

ENABLE_WAV_RECORDING=false
WAV_OUTPUT_DIR=../audio

COGNITIVE_PROTOCOL_ENABLED=true
ACTIVATION_PHRASE=hola alma
DEACTIVATION_PHRASES=gracias alma,adiós alma,detente alma

MAX_CONCURRENT_SESSIONS=50
SESSION_TIMEOUT_MS=1800000
RECONNECT_GRACE_PERIOD_MS=30000

LOG_LEVEL=info